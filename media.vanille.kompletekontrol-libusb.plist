<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>media.vanille.kompletekontrol-libusb</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/ccd</string>
        <string>--kk-libusb-daemon</string>
        <string>/var/run/kompletekontrol-libusb.sock</string>
    </array>
    <key>StandardOutPath</key>
    <string>/tmp/media.vanille.kompletekontrol-libusb.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/media.vanille.kompletekontrol-libusb.stderr.log</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
